# Lark Base Configuration
# Get these from Lark Open Platform: https://open.larksuite.com/
LARK_APP_ID=your_app_id_here
LARK_APP_SECRET=your_app_secret_here

# Base Configuration
BASE_APP_TOKEN=your_base_app_token_here

# Model API Configuration (for AI agents)
# Using domestic Chinese models as per competition requirements
MODEL_API_KEY=your_model_api_key_here
MODEL_API_ENDPOINT=https://api.example.com/v1

# Optional: Enable debug logging
DEBUG=false
