{
  "name": "hireloop",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered recruitment assistant built on Lark Base",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx scripts/run-tests.ts",
    "test:watch": "node --import tsx scripts/run-tests.ts --watch",
    "typecheck": "tsc --noEmit",
    "base:plan": "node --import tsx scripts/plan-base.ts",
    "base:seed:dry-run": "node --import tsx scripts/seed-base.ts",
    "base:seed:execute": "node --import tsx scripts/seed-base.ts --execute",
    "base:bootstrap:dry-run": "node --import tsx scripts/bootstrap-live-base.ts",
    "base:bootstrap:execute": "node --import tsx scripts/bootstrap-live-base.ts --execute",
    "base:migrate-schema:dry-run": "node --import tsx scripts/migrate-base-schema.ts",
    "base:migrate-schema:execute": "node --import tsx scripts/migrate-base-schema.ts --execute",
    "pipeline:demo": "node --import tsx scripts/demo-pipeline.ts",
    "pipeline:run": "node --import tsx scripts/run-agent-pipeline.ts",
    "report:demo": "node --import tsx scripts/demo-report.ts",
    "decision:demo": "node --import tsx scripts/demo-human-decision.ts",
    "mvp:demo": "node --import tsx scripts/demo-mvp.ts",
    "base:resolve:demo": "node --import tsx scripts/resolve-demo-records.ts",
    "base:resolve:sample": "node --import tsx scripts/resolve-demo-records.ts --sample-parse",
    "base:resolve:readonly": "node --import tsx scripts/resolve-demo-records.ts --execute-readonly",
    "mvp:live-ready": "node --import tsx scripts/demo-live-ready-mvp.ts",
    "mvp:live-write-plan": "node --import tsx scripts/demo-live-write-plan.ts",
    "mvp:live-write-plan:readonly": "node --import tsx scripts/demo-live-write-plan.ts --use-readonly-resolution",
    "mvp:live-readiness": "node --import tsx scripts/demo-live-readiness-report.ts",
    "mvp:live-recovery": "node --import tsx scripts/demo-live-recovery-plan.ts",
    "mvp:live-verification": "node --import tsx scripts/demo-live-verification-report.ts",
    "mvp:live-runbook": "node --import tsx scripts/demo-live-operator-runbook.ts",
    "mvp:live-e2e-runbook": "node --import tsx scripts/demo-live-e2e-runbook.ts",
    "mvp:release-gate": "node --import tsx scripts/demo-mvp-release-gate.ts",
    "mvp:pre-api-freeze": "node --import tsx scripts/demo-pre-api-freeze-report.ts",
    "mvp:provider-readiness": "node --import tsx scripts/demo-provider-adapter-readiness.ts",
    "mvp:provider-smoke": "node --import tsx scripts/run-provider-smoke.ts",
    "mvp:provider-smoke:execute": "node --import tsx scripts/run-provider-smoke.ts --execute --confirm=EXECUTE_PROVIDER_SMOKE",
    "mvp:live-write:dry-run": "node --import tsx scripts/run-live-mvp-writes.ts",
    "mvp:live-write:execute": "node --import tsx scripts/run-live-mvp-writes.ts --use-readonly-resolution --execute --confirm=EXECUTE_LIVE_MVP_WRITES",
    "mvp:provider-agent-demo": "node --import tsx scripts/run-provider-agent-demo.ts",
    "mvp:provider-agent-demo:execute": "node --import tsx scripts/run-provider-agent-demo.ts --use-provider --execute --confirm=EXECUTE_PROVIDER_AGENT_DEMO",
    "mvp:api-boundary-audit": "node --import tsx scripts/demo-api-boundary-release-audit.ts",
    "dataset:run": "node --import tsx scripts/run-live-agent-dataset.ts",
    "provider:dataset-verify": "node --import tsx scripts/run-provider-dataset-verify.ts",
    "competition:rag:prepare": "node --import tsx scripts/prepare-competition-rag.ts",
    "auto:demo-loop": "node --import tsx scripts/auto-demo-loop.ts",
    "feishu:events:long": "node --import tsx scripts/start-feishu-long-connection.ts",
    "ui:dev": "node --import tsx scripts/start-ui-server.ts",
    "scan:forbidden-traces": "node --import tsx scripts/run-forbidden-trace-scan.ts"
  },
  "keywords": [
    "recruitment",
    "ai",
    "lark",
    "feishu",
    "hr"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.62.1"
  }
}
