{
  "name": "hireloop",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered recruitment assistant built on Lark Base",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"src/**/*.test.ts\" \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "base:plan": "node --import tsx scripts/plan-base.ts",
    "base:seed:dry-run": "node --import tsx scripts/seed-base.ts",
    "base:seed:execute": "node --import tsx scripts/seed-base.ts --execute",
    "pipeline:demo": "node --import tsx scripts/demo-pipeline.ts",
    "report:demo": "node --import tsx scripts/demo-report.ts",
    "decision:demo": "node --import tsx scripts/demo-human-decision.ts",
    "mvp:demo": "node --import tsx scripts/demo-mvp.ts",
    "base:resolve:demo": "node --import tsx scripts/resolve-demo-records.ts",
    "base:resolve:sample": "node --import tsx scripts/resolve-demo-records.ts --sample-parse",
    "base:resolve:readonly": "node --import tsx scripts/resolve-demo-records.ts --execute-readonly",
    "mvp:live-ready": "node --import tsx scripts/demo-live-ready-mvp.ts",
    "mvp:live-write-plan": "node --import tsx scripts/demo-live-write-plan.ts",
    "mvp:live-write-plan:readonly": "node --import tsx scripts/demo-live-write-plan.ts --use-readonly-resolution",
    "mvp:live-readiness": "node --import tsx scripts/demo-live-readiness-report.ts",
    "mvp:live-recovery": "node --import tsx scripts/demo-live-recovery-plan.ts",
    "mvp:live-write:dry-run": "node --import tsx scripts/run-live-mvp-writes.ts",
    "mvp:live-write:execute": "node --import tsx scripts/run-live-mvp-writes.ts --use-readonly-resolution --execute --confirm=EXECUTE_LIVE_MVP_WRITES"
  },
  "keywords": [
    "recruitment",
    "ai",
    "lark",
    "feishu",
    "hr"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
